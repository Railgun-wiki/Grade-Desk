{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grade Desk",
  "version": "0.1.0",
  "identifier": "edu.sysu.grade-desk",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Grade Desk",
        "width": 1120,
        "height": 760,
        "minWidth": 320,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
